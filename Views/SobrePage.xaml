<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GVC.Mobile.Views.SobrePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Sobre"
    BackgroundColor="#F4F6F8">

    <ScrollView>
        <VerticalStackLayout
            Padding="24"
            Spacing="14"
            VerticalOptions="Center">

            <Label
                Text="GVC Mobile"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="#173B57"
                HorizontalTextAlignment="Center" />

            <Label
                Text="GVC Consulta offline de produtos, preços e estoque."
                FontSize="15"
                TextColor="#59656E"
                HorizontalTextAlignment="Center" />

            <Border
                Margin="0,15,0,0"
                Padding="18"
                BackgroundColor="White"
                Stroke="#DDE2E6">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>

                <Grid
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                    ColumnDefinitions="*,Auto"
                    RowSpacing="13">

                    <!-- Versão -->
                    <Label Text="Versão do aplicativo" />
                    <Label Grid.Column="1" x:Name="lblVersao" FontAttributes="Bold" />

                    <!-- Pacote -->
                    <Label Grid.Row="1" Text="Pacote" />
                    <Label Grid.Row="1" Grid.Column="1" Text="Android / iOS" FontAttributes="Bold" />

                    <!-- Sistema -->
                    <Label Grid.Row="2" Text="Sistema" />
                    <Label Grid.Row="2" Grid.Column="1" Text="GVC" FontAttributes="Bold" />

                    <!-- Desenvolvedor -->
                    <Label Grid.Row="3" Text="Desenvolvido por" />
                    <Label Grid.Row="3" Grid.Column="1" Text="GVC Tecnologia" FontAttributes="Bold" />

                    <!-- E-mail de suporte -->
                    <Label Grid.Row="4" Text="Suporte" />
                    <Label Grid.Row="4" Grid.Column="1" Text="suporte@gvc.com.br" FontAttributes="Bold" TextColor="#173B57" />

                    <!-- Site -->
                    <Label Grid.Row="5" Text="Site" />
                    <Label Grid.Row="5" Grid.Column="1" Text="www.gvc.com.br" FontAttributes="Bold" TextColor="#173B57" />

                </Grid>

            </Border>

            <!-- Direitos autorais completos -->
            <Label
                Text="© 2025 GVC Tecnologia. Todos os direitos reservados."
                FontSize="12"
                TextColor="#7C858D"
                HorizontalTextAlignment="Center"
                Margin="0,10,0,0" />

            <!-- Botão de ação (ex.: enviar e-mail) -->
            <Button
                Text="Fale conosco"
                BackgroundColor="#173B57"
                TextColor="White"
                CornerRadius="10"
                Clicked="OnFaleConoscoClicked"
                Margin="0,15,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>